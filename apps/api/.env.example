# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Pooled connection (pgbouncer, port 6543) — used by Prisma at runtime
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:6543/postgres?pgbouncer=true
# Direct connection (port 5432) — used by Prisma for migrations
DIRECT_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
REDIS_URL=rediss://[upstash-url]:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=                  # min 64 chars random string
JWT_REFRESH_SECRET=          # min 64 chars, different from JWT_SECRET

# ── Maps ──────────────────────────────────────────────────────────────────────
MAP_PROVIDER=                # "google" or "osm"
GOOGLE_MAPS_API_KEY=         # required when MAP_PROVIDER=google

# ── Billing (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Push notifications (FCM) ───────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=                    # development | production
PORT=4000
