{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "https://delivroute-7kxq.onrender.com/v1",
        "MAP_PROVIDER": "osm"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://delivroute-7kxq.onrender.com/v1",
        "MAP_PROVIDER": "osm"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://delivroute-7kxq.onrender.com/v1",
        "MAP_PROVIDER": "osm"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
