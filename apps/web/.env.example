# NextAuth — session encryption secret (min 32 chars) + canonical app URL
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Express API base (includes the /v1 prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Map provider: "osm" (Leaflet + OSM) or "google"
NEXT_PUBLIC_MAP_PROVIDER=osm
# Required only when NEXT_PUBLIC_MAP_PROVIDER=google
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
